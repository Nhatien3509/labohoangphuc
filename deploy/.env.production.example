# ============================================================================
# Bản mẫu biến môi trường PRODUCTION.
# - Dùng cho docker-compose: copy thành `deploy/.env` rồi sửa giá trị thật.
# - Hoặc tham khảo để điền env cho từng service trên Vibe Hosting.
# KHÔNG commit file `.env` thật lên git.
# ============================================================================

# ---- PostgreSQL ----
DB_USER=postgres
DB_PASSWORD=DOI_THANH_MAT_KHAU_MANH
DB_NAME=labo_warranty_db
DB_PORT=5432            # cổng publish ra host (chỉ dùng cho docker-compose)

# ---- Backend Go ----
APP_PORT=8080
# JWT_SECRET: chuỗi ngẫu nhiên dài >= 32 ký tự. Sinh nhanh: openssl rand -base64 48
JWT_SECRET=THAY_BANG_CHUOI_NGAU_NHIEN_THAT_DAI

# Tạo tài khoản admin lần khởi động đầu (ĐỔI MẬT KHẨU ngay sau khi đăng nhập)
SEED_ADMIN_EMAIL=admin@labo.vn
SEED_ADMIN_PASSWORD=DOI_THANH_MAT_KHAU_MANH

# ---- Frontend Next.js ----
WEB_PORT=3600
