# =============================================================================
# .dockerignore for Umbraco CMS Project
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# IDE và Editor
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*~
.DS_Store

# Build output
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
publish/
out/

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
!nuget.config

# Test results
TestResults/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# Runtime data
**/umbraco/Data/**
**/umbraco/Logs/**
**/umbraco/models/**
**/umbraco/Data/TEMP/**
*.sqlite.db
*.sqlite.db-shm
*.sqlite.db-wal

# Node modules (nếu có frontend build)
node_modules/
npm-debug.log
yarn-error.log

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Temporary files
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# Documentation (không cần trong container)
*.md
!README.md
CLAUDE.md
LICENSE.md
NOTICES.txt

# Workspace files
*.code-workspace

# Artifact ignore
.artifactignore

# Compose files
deploy/
docker-compose*.yml
*.env
*.env.*

# Tools
tools/

# Context files
context*.json
