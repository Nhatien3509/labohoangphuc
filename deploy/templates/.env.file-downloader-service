# Tuning
WORKER_COUNT=5
HTTP_TIMEOUT_SECONDS=120
APP_ENV=development

# Kafka native
KAFKA_BROKERS=dmst-kafka-1:9092,dmst-kafka-2:9092,dmst-kafka-3:9092
KAFKA_TOPIC_PATTERN=FILE_DOWNLOAD_REQUEST_.*
KAFKA_GROUP_ID=dmst-file-downloader

# Kong gateway
# Local dev: DOWNLOAD_BASE_URL=http://160.191.32.224:8000
DOWNLOAD_BASE_URL=http://kong:8000
GET_LINK_API_KEY_NAME=api-key
GET_LINK_API_KEY=thcsdl_secret_2026
DOWNLOAD_API_KEY_NAME=api-key
DOWNLOAD_API_KEY=thcsdl_download_secret_2026
GET_LINK_PATH_TEMPLATE=/api/v1/integration/TTDLQG/GET-LINK?id={fileId}
DOWNLOAD_PATH_TEMPLATE=/api/v1/integration/TTDLQG/DOWNLOAD-PUBLIC?token={token}


# Ozone S3-compatible gateway (Cloudera CDP PL7)
# Phase 1 POC (L0): gọi thẳng Ozone S3 Gateway port 9878
# Phase 2+ (L1): đổi sang Knox HTTPS: https://160.191.32.149:8443/gateway/cdp-proxy-api/s3
OZONE_ENDPOINT=http://160.191.32.149:9878
OZONE_BUCKET=zone2
# Khi ozone.security.enabled=false, bất kỳ giá trị nào cũng được chấp nhận
OZONE_ACCESS_KEY=anykey
OZONE_SECRET_KEY=anysecret
# Key path theo convention KS-Y: zone2/{maCapCha}/{maHtNguon}/{maLoaiDuLieu}/file/{itemId}/{tenTep}
OZONE_KEY_TEMPLATE={maCapCha}/{maHtNguon}/{maLoaiDuLieu}/file/{itemId}/{tenTep}

# Observability
LOG_LEVEL=info
SERVICE_NAME=dmst-file-downloader
OTEL_ENABLED=false
OTEL_ENDPOINT=otel-collector:4317

