# === Image Config ===
IMAGE_NAME="config-api"
IMAGE_TAG="v1.0.9-tintc"

# === Build Config ===
DOCKER_CONTEXT="../src/services/admin-service"
DOCKERFILE_PATH="Dockerfile"

# === Local Paths ===
# DÃ¹ng ${HOME} thay vÃ¬ ~ Ä‘á»ƒ Ä‘áº£m báº£o expand Ä‘Ãºng
LOCAL_COMPOSE_DIR="${DEPLOY_ROOT}/templates"
