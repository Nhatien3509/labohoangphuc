# === Image ===
IMAGE_NAME="dmst-mock-datasource"
IMAGE_TAG="v0.0.1-demo"

# === Build ===
DOCKER_CONTEXT="../dmst-mock-datasource"
DOCKERFILE_PATH="docker/mockds/Dockerfile"

# === Local Paths ===
LOCAL_COMPOSE_DIR="${DEPLOY_ROOT}/templates"
LOCAL_COMPOSE_FILE="ingest-stack.yml"
LOCAL_IMAGE_SAVE_DIR="${HOME}/Desktop/docker/images_backup"

# === Remote Paths ===
REMOTE_IMAGE_DIR="/home/h04/poc/docker-images"
REMOTE_COMPOSE_FILE="/home/h04/poc/tich-hop-chia-se/ingest/docker-compose.yml"
COMPOSE_SERVICE="mock-datasource"

# === SSH ===
SSH_AUTH_METHOD="key"
SSH_KEY_PATH="/home/tctin/Projects/GTSC/26.dmst.c12.tichhopchiase/dmst/secret-key/dmst.pem"
SERVERS="h04@160.191.32.193"

# === Health Check ===
HEALTH_CHECK_ENABLED="false"
HEALTH_CHECK_PORT="8090"
HEALTH_CHECK_PATH="/health"
HEALTH_CHECK_TIMEOUT="30"

# === Cleanup ===
IMAGE_RETENTION_HOURS="168"
