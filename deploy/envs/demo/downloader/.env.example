# ============================================
# DEPLOY CONFIGURATION â€” dmst-file-downloader
# Environment: demo
# ============================================

# === Image ===
IMAGE_NAME="dmst-file-downloader"
IMAGE_TAG="v0.0.1-demo"

# === Build ===
# Context is the Go service source directory (relative to DEPLOY_ROOT = deploy/)
DOCKER_CONTEXT="../srcs/dmst-file-downloader-svc"
DOCKERFILE_PATH="docker/downloader/Dockerfile"

# === Local Paths ===
LOCAL_COMPOSE_DIR="${DEPLOY_ROOT}/templates"
LOCAL_COMPOSE_FILE="file-downloader-stack.yml"
LOCAL_IMAGE_SAVE_DIR="${HOME}/Desktop/docker/images_backup"

# === Remote Paths ===
REMOTE_IMAGE_DIR="/home/h04/poc/docker-images"
REMOTE_COMPOSE_FILE="/home/h04/poc/tich-hop-chia-se/file-downloader/docker-compose.yml"
COMPOSE_SERVICE="dmst-downloader-services"

# === SSH ===
SSH_AUTH_METHOD="key"
SSH_KEY_PATH="/home/tctin/Projects/GTSC/26.dmst.c12.tichhopchiase/dmst/secret-key/dmst.pem"
SERVERS="h04@160.191.32.193"

# === Health Check ===
# Worker service â€” no HTTP endpoint to check
HEALTH_CHECK_ENABLED="false"

# === Cleanup ===
IMAGE_RETENTION_HOURS="168"
