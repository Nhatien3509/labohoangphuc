# ============================================
# ðŸ”§ DEPLOY CONFIGURATION - file-downloader-service
# ============================================

# === Image Config ===
IMAGE_NAME="thcs-file-downloader-service"
IMAGE_TAG="v0.2.0-chiennb"

# === Local Paths ===
LOCAL_COMPOSE_DIR="${DEPLOY_ROOT}/templates"
LOCAL_COMPOSE_FILE="file-downloader-service.yml"
LOCAL_IMAGE_SAVE_DIR="${HOME}/Desktop/docker/images_backup"

# === Remote Paths ===
REMOTE_IMAGE_DIR="/home/almalinux/docker-images"
REMOTE_COMPOSE_FILE="/home/almalinux/thcs/deployments/dev/file-downloader-service/docker-compose.yml"
COMPOSE_SERVICE="thcs-file-downloader-service"

# === SSH Authentication ===
SSH_AUTH_METHOD="key"
SSH_KEY_PATH="${HOME}/.ssh/dmst_key.pem"

# === Servers ===
SERVERS="almalinux@160.191.32.224"

# === Health Check ===
# Worker service - no HTTP endpoint
HEALTH_CHECK_ENABLED="false"

# === Cleanup ===
CLEANUP_OLD_IMAGES="true"
IMAGE_RETENTION_HOURS="168"
