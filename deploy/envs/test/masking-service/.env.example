# ============================================
# ðŸ”§ DEPLOY CONFIGURATION - masking-service
# ============================================

# === Image Config ===
IMAGE_NAME="thcs-masking-service"
IMAGE_TAG="v0.1.0"

# === Local Paths ===
LOCAL_COMPOSE_DIR="${DEPLOY_ROOT}/templates"
LOCAL_COMPOSE_FILE="masking-service.yml"
LOCAL_IMAGE_SAVE_DIR="${HOME}/Desktop/docker/images_backup"

# === Remote Paths ===
REMOTE_IMAGE_DIR="/home/almalinux/docker-images"
REMOTE_COMPOSE_FILE="/home/almalinux/thcs/deployments/dev/masking-service/docker-compose.yml"
COMPOSE_SERVICE="thcs-masking-service"

# === SSH Authentication ===
SSH_AUTH_METHOD="key"
SSH_KEY_PATH="${HOME}/.ssh/dmst_key.pem"

# === Servers ===
SERVERS="almalinux@160.191.32.224"

# === Health Check ===
HEALTH_CHECK_ENABLED="true"
HEALTH_CHECK_PORT="8080"
HEALTH_CHECK_PATH="/health"
HEALTH_CHECK_TIMEOUT="30"

# === Cleanup ===
CLEANUP_OLD_IMAGES="true"
IMAGE_RETENTION_HOURS="168"
