    {
      "name": "6. Cleanup",
      "item": [
        {
          "name": "Delete Private Route Config",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes/{{private_route_config_id}}",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes", "{{private_route_config_id}}"]
            }
