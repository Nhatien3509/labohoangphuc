    },
    {
      "name": "7. Demo Chi tiết tập dữ liệu",
      "item": [
        {
          "name": "7.1. Create Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('private_route_detail_config_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"system_code\": \"CDLQG\",\n  \"action_code\": \"CHI_TIET_DULIEU\",\n  \"version\": \"v1\",\n  \"app\": \"integration\",\n  \"upstream_url\": \"https://congdlqg.devlead.top/api/nguoidan/ud-tap-du-lieu/chi-tiet-tap-du-lieu-mo\",\n  \"strip_path\": true\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes"]
            },
            "description": "Tạo cấu hình route trong Kong cho API chi tiết tập dữ liệu."
          },
          "response": []
        },
        {
          "name": "7.2. Enable key-auth",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plugin_name\": \"key-auth\"\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes/{{private_route_detail_config_id}}/plugins",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes", "{{private_route_detail_config_id}}", "plugins"]
            },
            "description": "Bật bảo mật bằng API Key cho route vừa tạo."
          },
          "response": []
        },
        {
          "name": "7.3. Call Proxy",
          "request": {
            "method": "GET",
            "header": [{"key": "apikey", "value": "{{partner_api_key}}"}],
            "url": {
              "raw": "{{kong_proxy_url}}/api/v1/integration/CDLQG/CHI_TIET_DULIEU?Id=ee24b71f-7303-4f78-aff6-737885244378",
              "host": ["{{kong_proxy_url}}"],
              "path": ["api", "v1", "integration", "CDLQG", "CHI_TIET_DULIEU"],
              "query": [
                {"key": "Id", "value": "ee24b71f-7303-4f78-aff6-737885244378"}
              ]
            },
            "description": "Gọi API thông qua Kong Proxy với API Key."
          },
          "response": []
        }
      ]
