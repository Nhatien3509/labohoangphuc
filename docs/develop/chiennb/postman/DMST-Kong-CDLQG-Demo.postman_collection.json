{
  "info": {
    "_postman_id": "3dbcd8d2-5a4c-4d26-87b8-6f6d1cb0cf33",
    "name": "DMST Kong CDLQG Demo",
    "description": "Collection độc lập để demo CDLQG qua Kong: private route, public route, consumer, API key, plugin attach, history, rollback, cleanup. Lưu ý: plugin rate-limiting hiện chỉ được attach chắc chắn ở mức plugin_name; config chi tiết phải verify riêng trên Kong.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Health Check",
      "item": [
        {
          "name": "Check Admin API Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect 200 OK', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{admin_api_base_url}}/health",
              "host": ["{{admin_api_base_url}}"],
              "path": ["health"]
            },
            "description": "Kiểm tra Admin API còn sống trước khi demo."
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. Private Route Management",
      "item": [
        {
          "name": "Create Private Route Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('private_route_config_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"system_code\": \"CDLQG\",\n  \"action_code\": \"TIMKIEM_DULIEU\",\n  \"version\": \"v1\",\n  \"app\": \"integration\",\n  \"upstream_url\": \"https://congdlqg.devlead.top/api/nguoidan/ud-tap-du-lieu/tim-kiem\",\n  \"strip_path\": true\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes"]
            },
            "description": "Tạo private route v1/integration cho CDLQG."
          },
          "response": []
        },
        {
          "name": "List Route Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes"]
            }
          },
          "response": []
        },
        {
          "name": "Get Private Route Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes/{{private_route_config_id}}",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes", "{{private_route_config_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Consumer and Key",
      "item": [
        {
          "name": "Create Consumer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.ID) { pm.collectionVariables.set('consumer_id', jsonData.ID); }",
                  "if (jsonData.id) { pm.collectionVariables.set('consumer_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"cdlqg-partner-01\"\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/consumers",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "consumers"]
            }
          },
          "response": []
        },
        {
          "name": "Assign API Key to Consumer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"{{partner_api_key}}\"\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/consumers/{{consumer_id}}/keys",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "consumers", "{{consumer_id}}", "keys"]
            }
          },
          "response": []
        },
        {
          "name": "Enable key-auth on Private Route",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plugin_name\": \"key-auth\"\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes/{{private_route_config_id}}/plugins",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes", "{{private_route_config_id}}", "plugins"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Proxy Verification - Private",
      "item": [
        {
          "name": "Call Private Proxy WITHOUT API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect 401 Unauthorized', function () {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{kong_proxy_url}}/api/v1/integration/CDLQG/TIMKIEM_DULIEU?Keyword=&Page=1&Size=5",
              "host": ["{{kong_proxy_url}}"],
              "path": ["api", "v1", "integration", "CDLQG", "TIMKIEM_DULIEU"],
              "query": [
                {"key": "Keyword", "value": ""},
                {"key": "Page", "value": "1"},
                {"key": "Size", "value": "5"}
              ]
            }
          },
          "response": []
        },
        {
          "name": "Call Private Proxy WITH API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expect 200 OK', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "apikey", "value": "{{partner_api_key}}"}],
            "url": {
              "raw": "{{kong_proxy_url}}/api/v1/integration/CDLQG/TIMKIEM_DULIEU?Keyword=&Page=1&Size=5",
              "host": ["{{kong_proxy_url}}"],
              "path": ["api", "v1", "integration", "CDLQG", "TIMKIEM_DULIEU"],
              "query": [
                {"key": "Keyword", "value": ""},
                {"key": "Page", "value": "1"},
                {"key": "Size", "value": "5"}
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Public Route Management",
      "item": [
        {
          "name": "Create Public Route Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 200', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('public_route_config_id', jsonData.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"system_code\": \"CDLQG\",\n  \"action_code\": \"TIMKIEM_DULIEU\",\n  \"version\": \"v2\",\n  \"app\": \"public\",\n  \"upstream_url\": \"https://congdlqg.devlead.top/api/nguoidan/ud-tap-du-lieu/tim-kiem\",\n  \"strip_path\": true\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes"]
            },
            "description": "Tạo public route v2/public cho CDLQG."
          },
          "response": []
        },
        {
          "name": "Enable rate-limiting on Public Route",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plugin_name\": \"rate-limiting\",\n  \"config\": {\n    \"minute\": 5,\n    \"policy\": \"local\"\n  }\n}"
            },
            "url": {
              "raw": "{{admin_api_base_url}}/api/v1/routes/{{public_route_config_id}}/plugins",
              "host": ["{{admin_api_base_url}}"],
              "path": ["api", "v1", "routes", "{{public_route_config_id}}", "plugins"]
            },
            "description": "Attach rate-limiting ở mức plugin_name. Config chi tiết phải verify riêng trên Kong."
          },
          "response": []
        },
        {
          "name": "Call Public Proxy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{kong_proxy_url}}/api/v2/public/CDLQG/TIMKIEM_DULIEU?Keyword=&Page=1&Size=5",
              "host": ["{{kong_proxy_url}}"],
              "path": ["api", "v2", "public", "CDLQG", "TIMKIEM_DULIEU"],
              "query": [
                {"key": "Keyword", "value": ""},
                {"key": "Page", "value": "1"},
                {"key": "Size", "value": "5"}
              ]
            }
          },
          "response": []
        }
      ]
    },
