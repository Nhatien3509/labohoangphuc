# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.
#
# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

############################################################
# APP
############################################################

# Set to 0 for local, testing, and staging; set to 1 in production
NODE_TLS_REJECT_UNAUTHORIZED=0

# Comma-separated list of allowed origin IPs/hosts
ALLOWED_ORIGINS=

############################################################
# ENDPOINTS
# NOTE: Change each URL to match the target environment
#       (local / testing / staging / production)
############################################################

ORIGIN_URL=http://localhost:3000
CONSOLE_URL=http://localhost
BACKEND_URL=http://localhost:8000
GRAPHQL_URL=http://localhost:8183/graphql
REGISTRY_URL=http://localhost:8085
DOCS_URL=http://localhost:8181
CONTAINER_REGISTRY_URL=http://localhost:8181

############################################################
# AUTH
############################################################

# Keycloak OIDC — scope must contain "openid"
# https://github.com/nextauthjs/next-auth/discussions/3555#discussioncomment-7972994
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_SCOPE=openid profile
COOKIES_PASSWORD=

# Set BYPASS_AUTH=true only for local / testing environments
BYPASS_AUTH=false

# reCAPTCHA
BYPASS_CAPTCHA=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_VERIFY_URL=

############################################################
# E2E / PLAYWRIGHT
############################################################

TEST_USERNAME=
TEST_PASSWORD=
TEST_PROJECT=

############################################################
# FEATURE FLAGS
# Set to true/false to enable or disable each feature.
# Derived projects can add their own flags below this block.
############################################################

# UI
THEME_SWITCH_ENABLE=false

# Developer / debug
DEBUG_LOGS_ENABLE=false

# Auth
USE_BASIC_AUTH_ENABLE=false

# Observability
MONITORING_ENABLE=false
CLOUD_OBSERVABILITY_ENABLE=false
LOGS_ENABLE=false

# PAT (Personal Access Token)
PAT_ENABLE=false

# Networking
VPN_ENABLE=false
NETWORK_SHARE_VPC_ENABLE=false
NETWORK_DIRECT_CONNECT_ENABLE=false
NETWORK_DNS_ENABLE=false
NETWORK_LOAD_BALANCING_ENABLE=false

# Compute
SERVER_LIVE_RESIZE_ENABLE=false

# Storage
OBJECT_STORAGE_DATA_SYNC_JOB_ENABLE=false
OBJECT_STORAGE_DATA_SYNC_CONFIG_ENABLE=false
OBJECT_STORAGE_ENCRYPT_TYPE_ENABLE=false
FILE_STORAGE_ENABLE=false

# Security
KMS_ENABLE=false

# Managed services
DMS_ENABLE=false
DBAAS_ENABLE=false
CONTAINER_REGISTRY_ENABLE=false