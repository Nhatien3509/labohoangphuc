# L1 · Memory Layer — architecture.rules
#
# Tóm tắt máy-đọc của FE-Convention-Master §1, §11, §12.
# SOURCE-OF-TRUTH: docs/content/FE-Convention-Master.md — khi lệch, theo file đó.

[naming]                                  # §1
components   = PascalCase                 # UserProfileCard.tsx
hooks        = camelCase + use*           # useOrderFilters.ts
booleans     = is|has|can|should prefix   # isLoading, hasPermission
constants    = UPPER_SNAKE_CASE           # MAX_RETRY_COUNT
folders      = kebab-case                 # cloud-server

[types]                                   # §2.2
prefer = type                             # ưu tiên `type` hơn `interface`
forbid = any

[structure]                               # §11 — copy module `dbaas`, KHÔNG copy legacy
module_root = src/app/[locale]/(dashboard)/{module}/
_apis       = server.ts (read) | server.actions.ts ("use server" mutations) | types.ts | urns.ts
_lib        = const.ts | schemas.ts (zod) | validators.ts
module_owns = _apis/ _lib/ _hooks/ _stores/ _components/
page_files  = thin shell -> delegate to _components/

[aliases]                                 # §2.9 — bắt buộc, không relative ../../../
"@/*"         = src/
"@common/*"   = src/common/
"@{module}/*" = module root

[forbidden]                               # §6, §11, Phụ lục
cross_module_import = true                 # cấm @dbaas/* từ @cloud-server/*
copy_legacy_module  = true                 # template phải là `dbaas`
plain_html_table    = true                 # dùng CommonTable/DataTable
missing_dark_class  = true                 # mọi bg-*/text-* phải có dark:*
useState_for_filter = true                 # filter/pagination -> URL searchParams
hardcode_config     = true                 # base URL/key/timeout -> env/constants
console_log_prod    = true                 # chỉ console.warn/error
no_verify_bypass    = true                 # cấm --no-verify
