#!/usr/bin/env bash
# L5 · Distribution — "One install, every teammate aligned."
# Chạy 1 lần để mỗi thành viên có cùng skills/agents/hooks.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
KIT="$REPO_ROOT/src/web/portal-spa/agent-dev-kit"
CLAUDE_DIR="$REPO_ROOT/.claude"

echo "📦 Cài Agent Dev Kit cho repo này..."
mkdir -p "$CLAUDE_DIR/skills" "$CLAUDE_DIR/agents"

# L1 — Memory
ln -sf "$KIT/1-memory/project.md" "$REPO_ROOT/CLAUDE.md"

# L2 — Skills
ln -sf "$KIT/2-skills/new-module" "$CLAUDE_DIR/skills/new-module"

# L4 — Subagents
for a in code-reviewer test-runner explorer; do
  ln -sf "$KIT/4-subagents/$a.md" "$CLAUDE_DIR/agents/$a.md"
done

echo "✅ Đã link L1/L2/L4."
echo "⚠️ L3 (hooks): merge thủ công agent-dev-kit/3-hooks/settings.example.json"
echo "   vào $CLAUDE_DIR/settings.json (mục 'hooks')."
echo "🎉 Mọi teammate giờ dùng chung cấu hình agent."
