{
  "name": "portal-spa",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 4800",
    "build": "next build",
    "start": "next start -p 4800",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:prettier:fix",
    "lint:prettier": "prettier --cache --check .",
    "lint:prettier:fix": "prettier --cache --write .",
    "lint:eslint": "eslint --cache .",
    "lint:eslint:fix": "eslint --cache --fix .",
    "lint:staged": "lint-staged",
    "check:conventions": "sh scripts/check-fe-conventions.sh",
    "prepare": "node scripts/setup-git-hooks.mjs || exit 0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "gen:module": "node tools/generate-feature/cli.mjs module",
    "test:gen": "node --test tools/generate-feature/lib/slug.test.mjs tools/generate-feature/lib/patch-config.test.mjs tools/generate-feature/lib/patch-feature-flag.test.mjs"
  },
  "lint-staged": {
    "{src,__tests__,.storybook,types}/**/*.{cjs,js,jsx,mjs,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "{eslint.config.mjs,next.config.js,tailwind.config.ts,vitest.config.ts,postcss.config.cjs,prettier.config.js}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
